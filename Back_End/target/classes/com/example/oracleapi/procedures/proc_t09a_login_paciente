create or replace PROCEDURE proc_t09a_login_paciente (
    p_nome IN VARCHAR2,
    p_senha IN VARCHAR2
)
AS
    v_nome  t09a_paciente.nome%TYPE;
    v_senha t09a_paciente.senha%TYPE;
    v_sucesso VARCHAR2(200) := 'Usuário logado com sucesso!';
    v_erro1 VARCHAR2(200) := 'Usuário não existe na base de dados.';
    v_erro2 VARCHAR2(200) := 'Erro inesperado!';
BEGIN
    -- Tenta buscar o paciente com o nome e senha informados
    SELECT nome, senha INTO v_nome, v_senha
    FROM t09a_paciente
    WHERE nome = p_nome AND senha = p_senha;

    -- Exibe mensagem de sucesso
    DBMS_OUTPUT.PUT_LINE(v_sucesso);

EXCEPTION
    WHEN NO_DATA_FOUND THEN
                DBMS_OUTPUT.PUT_LINE(v_erro1);
        RAISE_APPLICATION_ERROR(-20001, 'Usuário não existe na base de dados.');
    WHEN OTHERS THEN
                DBMS_OUTPUT.PUT_LINE(v_erro2);
        RAISE_APPLICATION_ERROR(-20002, 'Erro inesperado: ' || SQLERRM);
END;
