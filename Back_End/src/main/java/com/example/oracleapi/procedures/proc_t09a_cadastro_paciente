CREATE OR REPLACE PROCEDURE proc_t09a_cadastro_paciente
(
  p_email            IN VARCHAR2,
  p_senha            IN VARCHAR2,
  p_cpf              IN VARCHAR2,
  p_sexo             IN CHAR,
  p_telefone         IN VARCHAR2,
  p_nome             IN VARCHAR2,
  p_data_nascimento  IN DATE,
  p_ativo            IN CHAR DEFAULT 'S',
  p_data_cadastro    IN DATE DEFAULT SYSDATE
)
AS
    v_nome VARCHAR2(100);
    v_cpf VARCHAR2(11);
    v_senha VARCHAR2(30);
    v_erro1 VARCHAR2(100) := 'Erro: Usuario já cadastrado na base de dados';
    v_erro2 VARCHAR2(100) := 'Erro: Senha já cadastrada';
    v_erro3 VARCHAR2(100) := 'Erro: Email já cadastrado';
BEGIN
    SELECT COUNT(*) INTO v_nome FROM t09a_paciente WHERE nome = p_nome;
    IF v_nome > 0 THEN
        DBMS_OUTPUT.PUT_LINE(v_erro1);
        RAISE_APPLICATION_ERROR(-20001, v_erro1);
    END IF;

    SELECT COUNT(*) INTO v_senha FROM t09a_paciente WHERE senha = p_senha;
    IF v_senha > 0 THEN
        DBMS_OUTPUT.PUT_LINE(v_erro2);
        RAISE_APPLICATION_ERROR(-20002, v_erro2);
    END IF;

    SELECT COUNT(*) INTO v_cpf FROM t09a_paciente WHERE cpf = p_cpf;
    IF v_cpf > 0 THEN
        DBMS_OUTPUT.PUT_LINE(v_erro3);
        RAISE_APPLICATION_ERROR(-20003, v_erro3);
    END IF;

    INSERT INTO t09a_paciente (CPF, DATA_NASCIMENTO, EMAIL, NOME, SENHA, SEXO, TELEFONE, ATIVO, DATA_CADASTRO )
    VALUES(p_cpf, p_data_nascimento, p_email, p_nome, p_senha, p_sexo, p_telefone, p_ativo, p_data_cadastro);

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('Erro: Registro não encontrado.');
        RAISE_APPLICATION_ERROR(-20004, 'Erro: Registro não encontrado.');
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Erro inesperado: ' || SQLERRM);
        RAISE_APPLICATION_ERROR(-20005, 'Erro inesperado: ' || SQLERRM);
END proc_t09a_cadastro_paciente;
